{
  "$schema": "https://raw.githubusercontent.com/VitexSoftware/php-vitexsoftware-multiflexi-core/refs/heads/main/multiflexi.app.schema.json",
  "schemaVersion": "3.4.0",
  "uuid": "138f1310-8e76-4670-bc55-47a3400795e1",
  "name": {
    "en": "Clear Reminder Labels",
    "cs": "Vyčistit štítky upomínek"
  },
  "description": {
    "en": "Clear Debtor's labels",
    "cs": "Vyčistit štítky dlužníků"
  },
  "tags": [
    "AbraFlexi",
    "Reminder",
    "Labels"
  ],
  "requirements": [
    "AbraFlexi"
  ],
  "homepage": "https://github.com/VitexSoftware/abraflexi-reminder",
  "executable": "abraflexi-reminder-clean-labels",
  "events": {
    "listens": {
      "invoice.settled": {
        "description": "Triggered when an invoice is fully paid; ABRAFLEXI_CUSTOMER should be mapped to the customer code from the event"
      }
    },
    "emits": {
      "reminder.labels.cleared": {
        "description": "Reminder labels were cleared"
      }
    }
  },
  "environment": {
    "LANG": {
      "type": "set",
      "description": {
        "en": "Locale for this application",
        "cs": "Lokalizace pro tuto aplikaci"
      },
      "defval": "cs_CZ",
      "required": false,
      "options": [
        "cs_CZ",
        "en_US"
      ],
      "category": "Other"
    },
    "ABRAFLEXI_COMPANY": {
      "type": "string",
      "description": "",
      "defval": "demo_de",
      "required": true,
      "category": "API"
    },
    "ABRAFLEXI_LOGIN": {
      "type": "string",
      "description": {
        "en": "AbraFlexi Login",
        "cs": "AbraFlexi Login"
      },
      "defval": "winstrom",
      "required": true,
      "category": "API"
    },
    "ABRAFLEXI_PASSWORD": {
      "type": "password",
      "description": {
        "en": "AbraFlexi password",
        "cs": "AbraFlexi heslo"
      },
      "defval": "winstrom",
      "required": true,
      "category": "API"
    },
    "ABRAFLEXI_URL": {
      "type": "string",
      "description": {
        "en": "AbraFlexi Server URI",
        "cs": "AbraFlexi Server URI"
      },
      "defval": "https://demo.flexibee.eu:5434",
      "required": true,
      "category": "API"
    },
    "ABRAFLEXI_CUSTOMER": {
      "type": "string",
      "description": {
        "en": "Customer code (adresar/kod) for event-driven single-customer mode. When set, only this customer is checked and cleaned. Leave empty for batch mode (all labelled customers).",
        "cs": "Kód zákazníka (adresar/kod) pro událostní jednozákaznický režim. Je-li nastaveno, zkontroluje se a vyčistí pouze tento zákazník. Prázdné = hromadný režim."
      },
      "defval": "",
      "required": false,
      "category": "Behavior"
    },
    "EASE_LOGGER": {
      "type": "string",
      "description": {
        "en": "write log messages using",
        "cs": "zapsat log zprávy pomocí"
      },
      "defval": "console|syslog",
      "required": false,
      "category": "Behavior"
    }
  },
  "exitCodes": {
    "0": {
      "description": {
        "en": "Success",
        "cs": "Úspěch"
      },
      "severity": "success",
      "retry": false
    }
  }
}
