#!/usr/bin/make -f

PKG_VERSION := $(shell dpkg-parsechangelog -S Version | sed 's/~.*//')
PKG_SOURCE  := $(shell jq -r '.name' composer.json)
PKG_TYPE    := $(shell jq -r '.type' composer.json)

%:
	dh $@ --with phpcomposer

override_dh_prep:
	rm -rf vendor
	dh_prep

override_dh_install:
	dh_install
	install -D -m 0644 debian/autoload.php debian/abraflexi-reminder/usr/share/php/abraflexi-reminder/autoload.php
	sed -i "1a defined('APP_NAME') || define('APP_NAME', '$(PKG_SOURCE)');" \
	    debian/abraflexi-reminder/usr/share/php/abraflexi-reminder/autoload.php
	sed -i "s|'unknown'|'$(PKG_SOURCE)'|" debian/abraflexi-reminder/usr/share/php/abraflexi-reminder/autoload.php
	sed -i "s|'0.0.0'|'$(PKG_VERSION)'|" debian/abraflexi-reminder/usr/share/php/abraflexi-reminder/autoload.php
	sed -i "s|'library'|'$(PKG_TYPE)'|g" debian/abraflexi-reminder/usr/share/php/abraflexi-reminder/autoload.php
	sed -i "2a defined('APP_VERSION') || define('APP_VERSION', '$(PKG_VERSION)');" \
	    debian/abraflexi-reminder/usr/share/php/abraflexi-reminder/autoload.php
	jq '.version = "$(PKG_VERSION)"' debian/conf/composer.json | sponge debian/abraflexi-reminder/usr/lib/abraflexi-reminder/composer.json
	sed -i -e 's/..../\/usr\/share\/locale/g'                     debian/abraflexi-reminder/usr/share/abraflexi-reminder/*.php
	sed -i -e 's/..../\/usr\/share\/php\/abraflexi-reminder/g'    debian/abraflexi-reminder/usr/share/abraflexi-reminder/*.php
	sed -i -e 's/.\/AbraFlexi\/Reminder\/Notifier/\/usr\/lib\/abraflexi-reminder\/Reminder\/Notifier/g' debian/abraflexi-reminder/usr/share/abraflexi-reminder/*.php
	sed -i -e 's/..\/bin/\/usr\/bin/g'                            debian/abraflexi-reminder-gnokii/usr/lib/abraflexi-reminder/Reminder/*Gnokii.php
	sed -i -e 's/..\/.env//'                                      debian/abraflexi-reminder/usr/share/abraflexi-reminder/*.php
	jq '.version = "$(PKG_VERSION)"' multiflexi/clear_reminder_labels.multiflexi.app.json   | sponge debian/multiflexi-abraflexi-reminder/usr/lib/abraflexi-reminder/multiflexi/clear_reminder_labels.multiflexi.app.json
	jq '.version = "$(PKG_VERSION)"' multiflexi/debts_overview.multiflexi.app.json           | sponge debian/multiflexi-abraflexi-reminder/usr/lib/abraflexi-reminder/multiflexi/debts_overview.multiflexi.app.json
	jq '.version = "$(PKG_VERSION)"' multiflexi/inventarize.multiflexi.app.json              | sponge debian/multiflexi-abraflexi-reminder/usr/lib/abraflexi-reminder/multiflexi/inventarize.multiflexi.app.json
	jq '.version = "$(PKG_VERSION)"' multiflexi/abraflexi-reminder.multiflexi.app.json       | sponge debian/multiflexi-abraflexi-reminder/usr/lib/abraflexi-reminder/multiflexi/abraflexi-reminder.multiflexi.app.json

override_dh_auto_test:
	appstreamcli validate --pedantic --no-net \
	    debian/io.github.vitexsoftware.abraflexi_reminder.metainfo.xml
